generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH MODULE
// ============================================================

model auth_users {
  id            String   @id @default(uuid())
  tenant_id     String
  branch_id     String
  username      String
  email         String?
  password_hash String
  full_name     String
  role_id       String
  status        String   @default("ACTIVE") // ACTIVE, INACTIVE
  created_at    DateTime @default(now())
  created_by    String
  updated_at    DateTime @updatedAt
  updated_by    String
  version       Int      @default(1)

  role   auth_roles   @relation(fields: [role_id], references: [id])
  branch mdm_branches @relation(fields: [branch_id], references: [id])

  @@unique([tenant_id, username])
  @@index([tenant_id, branch_id])
}

model auth_roles {
  id          String   @id @default(uuid())
  tenant_id   String
  name        String
  code        String   // RECEPTIONIST, LAB_TECHNICIAN, PATHOLOGIST, CENTER_HEAD, FINANCE_MANAGER, SYSTEM_ADMIN
  description String?
  created_at  DateTime @default(now())
  created_by  String
  updated_at  DateTime @updatedAt
  updated_by  String
  version     Int      @default(1)

  users       auth_users[]
  permissions auth_role_permissions[]

  @@unique([tenant_id, code])
}

model auth_permissions {
  id          String   @id @default(uuid())
  code        String   @unique // e.g. billing:create, lims:sign-off
  description String?
  module      String   // auth, mdm, billing, lims, finance, reporting
  created_at  DateTime @default(now())

  roles auth_role_permissions[]
}

model auth_role_permissions {
  id            String @id @default(uuid())
  role_id       String
  permission_id String

  role       auth_roles       @relation(fields: [role_id], references: [id])
  permission auth_permissions @relation(fields: [permission_id], references: [id])

  @@unique([role_id, permission_id])
}

// ============================================================
// MDM MODULE
// ============================================================

model mdm_branches {
  id                   String   @id @default(uuid())
  tenant_id            String
  code                 String
  name                 String
  address              String?
  gstin                String?
  default_rate_plan_id String?
  status               String   @default("ACTIVE")
  created_at           DateTime @default(now())
  created_by           String
  updated_at           DateTime @updatedAt
  updated_by           String
  version              Int      @default(1)

  users      auth_users[]
  visits     lims_visits[]
  bills      billing_bills[]
  payments   billing_payments[]
  accessions   lims_accessions[]
  shifts       finance_shifts[]
  daily_closes finance_daily_close[]

  @@unique([tenant_id, code])
}

model mdm_patients {
  id                         String    @id @default(uuid())
  tenant_id                  String
  patient_code               String
  full_name                  String
  gender                     String    // MALE, FEMALE, OTHER
  dob                        DateTime?
  age_years                  Int?
  mobile                     String
  email                      String?
  address                    String?
  preferred_language         String?   // EN, HI
  preferred_delivery_channel String?   // WHATSAPP, EMAIL, PRINT_ONLY
  status                     String    @default("ACTIVE")
  created_at                 DateTime  @default(now())
  created_by                 String
  updated_at                 DateTime  @updatedAt
  updated_by                 String
  version                    Int       @default(1)

  visits lims_visits[]

  @@unique([tenant_id, patient_code])
  @@index([tenant_id, mobile])
}

model mdm_doctors {
  id                 String   @id @default(uuid())
  tenant_id          String
  doctor_code        String
  name               String
  specialty          String?
  mobile             String?
  linked_rate_plan_id String?
  status             String   @default("ACTIVE")
  created_at         DateTime @default(now())
  created_by         String
  updated_at         DateTime @updatedAt
  updated_by         String
  version            Int      @default(1)

  linked_rate_plan mdm_rate_plans? @relation(fields: [linked_rate_plan_id], references: [id])
  visits           lims_visits[]
  bills            billing_bills[]

  @@unique([tenant_id, doctor_code])
}

model mdm_tests {
  id               String   @id @default(uuid())
  tenant_id        String
  test_code        String
  name             String
  department       String   // HEMATOLOGY, BIOCHEMISTRY, MICROBIOLOGY, IMMUNOLOGY, PATHOLOGY
  sample_type      String   // BLOOD, SERUM, URINE, SWAB, PLASMA
  tat_hours        Int      @default(24)
  base_mrp         Decimal  @db.Decimal(12, 2)
  lis_mapping_code String?
  reference_range  String?  // e.g. "4.5-11.0" or "Negative"
  unit             String?  // e.g. "10^3/uL", "mg/dL"
  active           Boolean  @default(true)
  created_at       DateTime @default(now())
  created_by       String
  updated_at       DateTime @updatedAt
  updated_by       String
  version          Int      @default(1)

  bill_items      billing_bill_items[]
  test_orders     lims_test_orders[]
  package_tests   mdm_package_tests[]
  rate_plan_tests mdm_rate_plan_tests[]

  @@unique([tenant_id, test_code])
}

model mdm_packages {
  id           String   @id @default(uuid())
  tenant_id    String
  package_code String
  name         String
  active       Boolean  @default(true)
  created_at   DateTime @default(now())
  created_by   String
  updated_at   DateTime @updatedAt
  updated_by   String
  version      Int      @default(1)

  package_tests   mdm_package_tests[]
  rate_plan_tests mdm_rate_plan_tests[]
  bill_items      billing_bill_items[]

  @@unique([tenant_id, package_code])
}

model mdm_package_tests {
  id         String  @id @default(uuid())
  tenant_id  String
  package_id String
  test_id    String
  active     Boolean @default(true)

  package mdm_packages @relation(fields: [package_id], references: [id])
  test    mdm_tests    @relation(fields: [test_id], references: [id])

  @@unique([package_id, test_id])
}

model mdm_rate_plans {
  id             String    @id @default(uuid())
  tenant_id      String
  name           String
  plan_type      String    // MRP, BRANCH_DEFAULT, PAYER_TYPE, CORPORATE, REFERRER
  priority       Int       // lower number = higher priority
  effective_from DateTime
  effective_to   DateTime?
  status         String    @default("ACTIVE")
  created_at     DateTime  @default(now())
  created_by     String
  updated_at     DateTime  @updatedAt
  updated_by     String
  version        Int       @default(1)

  rate_plan_tests mdm_rate_plan_tests[]
  doctors         mdm_doctors[]

  @@index([tenant_id, plan_type, status])
}

model mdm_rate_plan_tests {
  id               String  @id @default(uuid())
  tenant_id        String
  rate_plan_id     String
  test_id          String
  price            Decimal @db.Decimal(12, 2)
  discount_percent Decimal @default(0) @db.Decimal(5, 2)
  is_package       Boolean @default(false)
  package_id       String?

  rate_plan mdm_rate_plans @relation(fields: [rate_plan_id], references: [id])
  test      mdm_tests      @relation(fields: [test_id], references: [id])
  package   mdm_packages?  @relation(fields: [package_id], references: [id])

  @@index([tenant_id, rate_plan_id])
  @@index([tenant_id, test_id])
}

// ============================================================
// LIMS MODULE
// ============================================================

model lims_visits {
  id                    String   @id @default(uuid())
  tenant_id             String
  branch_id             String
  visit_number          String
  patient_id            String
  visit_type            String   @default("WALK_IN") // WALK_IN, HOME_COLLECTION, CAMP, CORPORATE
  payer_type            String   @default("SELF")    // SELF, CORPORATE, INSURANCE
  referrer_id           String?
  prescription_image_url String?
  extracted_data_json   Json?    // AI extraction output for audit
  extraction_provider   String?  // mock | claude | google | tesseract | manual
  fasting_status        String?  // FASTING, NON_FASTING, NOT_APPLICABLE
  pregnancy_status      String?  // PREGNANT, NOT_PREGNANT, NOT_APPLICABLE
  created_at            DateTime @default(now())
  created_by            String
  updated_at            DateTime @updatedAt
  updated_by            String
  version               Int      @default(1)

  patient   mdm_patients  @relation(fields: [patient_id], references: [id])
  branch    mdm_branches  @relation(fields: [branch_id], references: [id])
  referrer  mdm_doctors?  @relation(fields: [referrer_id], references: [id])
  bill      billing_bills?
  accession lims_accessions?

  @@index([tenant_id, patient_id, created_at(sort: Desc)])
}

model lims_accessions {
  id                String    @id @default(uuid())
  tenant_id         String
  branch_id         String
  accession_number  String
  visit_id          String    @unique
  bill_id           String    @unique
  accession_status  String    @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, CANCELLED
  accessioned_at    DateTime  @default(now())
  created_at        DateTime  @default(now())
  created_by        String
  updated_at        DateTime  @updatedAt
  updated_by        String
  version           Int       @default(1)

  visit   lims_visits    @relation(fields: [visit_id], references: [id])
  bill    billing_bills  @relation(fields: [bill_id], references: [id])
  branch  mdm_branches   @relation(fields: [branch_id], references: [id])
  samples lims_samples[]
  test_orders lims_test_orders[]
  reports lims_reports[]

  @@unique([tenant_id, accession_number])
  @@index([tenant_id, branch_id])
}

model lims_samples {
  id              String    @id @default(uuid())
  tenant_id       String
  accession_id    String
  sample_code     String
  sample_type     String    // BLOOD, SERUM, URINE, SWAB, PLASMA
  collection_time DateTime?
  received_time   DateTime?
  sample_status   String    @default("PENDING_COLLECTION")
  // PENDING_COLLECTION, COLLECTED, RECEIVED_AT_LAB, IN_PROCESS, COMPLETED, REJECTED
  rejection_reason String?
  created_at      DateTime  @default(now())
  created_by      String
  updated_at      DateTime  @updatedAt
  updated_by      String
  version         Int       @default(1)

  accession   lims_accessions   @relation(fields: [accession_id], references: [id])
  test_orders lims_test_orders[]

  @@index([tenant_id, accession_id])
}

model lims_test_orders {
  id           String    @id @default(uuid())
  tenant_id    String
  accession_id String
  bill_item_id String?
  test_id      String
  department   String
  sample_id    String?
  order_status String    @default("ORDERED")
  // ORDERED, IN_PROCESS, COMPLETED, APPROVED, RECOLLECTION_REQUIRED
  assigned_to  String?
  started_at   DateTime?
  completed_at DateTime?
  created_at   DateTime  @default(now())
  created_by   String
  updated_at   DateTime  @updatedAt
  updated_by   String
  version      Int       @default(1)

  accession lims_accessions     @relation(fields: [accession_id], references: [id])
  test      mdm_tests           @relation(fields: [test_id], references: [id])
  sample    lims_samples?       @relation(fields: [sample_id], references: [id])
  result    lims_results?

  @@index([tenant_id, accession_id])
  @@index([tenant_id, department, order_status])
}

model lims_results {
  id              String    @id @default(uuid())
  tenant_id       String
  test_order_id   String    @unique
  raw_value       String
  unit            String?
  reference_range String?
  flag            String?   // NORMAL, HIGH, LOW, CRITICAL
  comments        String?
  approved_by     String?
  approved_at     DateTime?
  created_at      DateTime  @default(now())
  created_by      String
  updated_at      DateTime  @updatedAt
  updated_by      String
  version         Int       @default(1)

  test_order lims_test_orders @relation(fields: [test_order_id], references: [id])

  @@index([tenant_id, test_order_id])
}

model lims_reports {
  id             String    @id @default(uuid())
  tenant_id      String
  accession_id   String
  report_number  String
  generated_at   DateTime  @default(now())
  signed_off_by  String?
  signed_off_at  DateTime?
  report_status  String    @default("GENERATED") // GENERATED, SIGNED_OFF, AMENDED
  pdf_path       String?
  created_at     DateTime  @default(now())
  created_by     String
  updated_at     DateTime  @updatedAt
  updated_by     String
  version        Int       @default(1)

  accession     lims_accessions          @relation(fields: [accession_id], references: [id])
  delivery_logs lims_report_delivery_logs[]

  @@index([tenant_id, accession_id])
}

model lims_report_delivery_logs {
  id             String    @id @default(uuid())
  tenant_id      String
  report_id      String
  channel        String    // WHATSAPP, EMAIL, SMS
  target         String    // phone number or email
  status         String    @default("PENDING") // PENDING, SENT, FAILED
  sent_at        DateTime?
  failure_reason String?
  created_at     DateTime  @default(now())
  created_by     String
  updated_at     DateTime  @updatedAt
  updated_by     String
  version        Int       @default(1)

  report lims_reports @relation(fields: [report_id], references: [id])

  @@index([tenant_id, report_id])
}

// ============================================================
// BILLING MODULE
// ============================================================

model billing_bills {
  id                   String   @id @default(uuid())
  tenant_id            String
  branch_id            String
  bill_number          String
  visit_id             String   @unique
  bill_date            DateTime @default(now())
  gross_amount         Decimal  @db.Decimal(12, 2)
  discount_amount      Decimal  @default(0) @db.Decimal(12, 2)
  net_amount           Decimal  @db.Decimal(12, 2)
  tax_amount           Decimal  @default(0) @db.Decimal(12, 2)
  rounding_adjustment  Decimal  @default(0) @db.Decimal(12, 2)
  final_amount         Decimal  @db.Decimal(12, 2)
  bill_status          String   @default("DRAFT")
  // DRAFT, PENDING_PAYMENT, PARTIALLY_PAID, PAID, CANCELLED, REFUNDED
  payment_status       String   @default("UNPAID")
  // UNPAID, PARTIALLY_PAID, PAID
  payer_type           String   @default("SELF")
  referrer_id          String?
  discount_reason_code String?
  qr_code              String?  // encoded payload for status lookup
  created_at           DateTime @default(now())
  created_by           String
  updated_at           DateTime @updatedAt
  updated_by           String
  version              Int      @default(1)

  visit      lims_visits          @relation(fields: [visit_id], references: [id])
  branch     mdm_branches         @relation(fields: [branch_id], references: [id])
  referrer   mdm_doctors?         @relation(fields: [referrer_id], references: [id])
  items      billing_bill_items[]
  payments   billing_payments[]
  accession  lims_accessions?
  adjustments billing_adjustments[]

  @@unique([tenant_id, bill_number])
  @@index([tenant_id, branch_id, bill_date(sort: Desc)])
  @@index([tenant_id, bill_status, payment_status])
}

model billing_bill_items {
  id                    String  @id @default(uuid())
  tenant_id             String
  bill_id               String
  test_id               String
  item_type             String  @default("TEST") // TEST, PACKAGE
  parent_bill_item_id   String?
  billing_visible       Boolean @default(true)
  package_id            String?
  quantity              Int     @default(1)
  mrp_amount            Decimal @db.Decimal(12, 2)
  rate_plan_id          String?
  line_discount_amount  Decimal @default(0) @db.Decimal(12, 2)
  final_amount          Decimal @db.Decimal(12, 2)
  created_at            DateTime @default(now())
  created_by            String
  updated_at            DateTime @updatedAt
  updated_by            String
  version               Int     @default(1)

  bill    billing_bills  @relation(fields: [bill_id], references: [id])
  test    mdm_tests      @relation(fields: [test_id], references: [id])
  package mdm_packages?  @relation(fields: [package_id], references: [id])

  @@index([tenant_id, bill_id])
}

model billing_payments {
  id                 String    @id @default(uuid())
  tenant_id          String
  branch_id          String
  payment_reference  String
  bill_id            String
  mode               String    // CASH, UPI, CARD, NEFT, CHEQUE
  amount             Decimal   @db.Decimal(12, 2)
  instrument_details String?
  upi_rrn            String?
  gateway_txn_id     String?
  status             String    @default("SUCCESS") // INITIATED, SUCCESS, FAILED, REVERSED
  received_at        DateTime  @default(now())
  shift_id           String?
  created_at         DateTime  @default(now())
  created_by         String
  updated_at         DateTime  @updatedAt
  updated_by         String
  version            Int       @default(1)

  bill   billing_bills @relation(fields: [bill_id], references: [id])
  branch mdm_branches  @relation(fields: [branch_id], references: [id])

  @@index([tenant_id, bill_id])
  @@index([tenant_id, branch_id, received_at(sort: Desc)])
}

model billing_adjustments {
  id                String    @id @default(uuid())
  tenant_id         String
  branch_id         String
  bill_id           String
  adjustment_number String
  type              String    // CREDIT_NOTE, REFUND
  amount            Decimal   @db.Decimal(12, 2)
  reason_code       String
  remarks           String?
  status            String    @default("DRAFT") // DRAFT, APPROVED, POSTED, VOID
  approved_by       String?
  approved_at       DateTime?
  created_at        DateTime  @default(now())
  created_by        String
  updated_at        DateTime  @updatedAt
  updated_by        String
  version           Int       @default(1)

  bill billing_bills @relation(fields: [bill_id], references: [id])

  @@unique([tenant_id, adjustment_number])
  @@index([tenant_id, bill_id])
  @@index([tenant_id, type, status])
}

// ============================================================
// FINANCE MODULE
// ============================================================

model finance_shifts {
  id              String    @id @default(uuid())
  tenant_id       String
  branch_id       String
  shift_number    String
  user_id         String    // cashier
  opened_at       DateTime  @default(now())
  closed_at       DateTime?
  status          String    @default("OPEN") // OPEN, CLOSED
  // System totals (calculated from billing_payments)
  system_cash     Decimal   @default(0) @db.Decimal(12, 2)
  system_upi      Decimal   @default(0) @db.Decimal(12, 2)
  system_card     Decimal   @default(0) @db.Decimal(12, 2)
  system_other    Decimal   @default(0) @db.Decimal(12, 2)
  // Physical counts (entered by cashier)
  actual_cash     Decimal?  @db.Decimal(12, 2)
  actual_upi      Decimal?  @db.Decimal(12, 2)
  actual_card     Decimal?  @db.Decimal(12, 2)
  actual_other    Decimal?  @db.Decimal(12, 2)
  // Variance
  variance_cash   Decimal?  @db.Decimal(12, 2)
  variance_upi    Decimal?  @db.Decimal(12, 2)
  variance_card   Decimal?  @db.Decimal(12, 2)
  variance_other  Decimal?  @db.Decimal(12, 2)
  variance_reason String?
  approved_by     String?   // center head approval if variance exceeds threshold
  created_at      DateTime  @default(now())
  created_by      String
  updated_at      DateTime  @updatedAt
  updated_by      String
  version         Int       @default(1)

  branch mdm_branches @relation(fields: [branch_id], references: [id])

  @@unique([tenant_id, shift_number])
  @@index([tenant_id, branch_id, status])
}

model finance_daily_close {
  id                String    @id @default(uuid())
  tenant_id         String
  branch_id         String
  close_date        String    // YYYY-MM-DD
  status            String    @default("OPEN") // OPEN, CLOSED
  total_bills       Int       @default(0)
  total_revenue     Decimal   @default(0) @db.Decimal(12, 2)
  total_cash        Decimal   @default(0) @db.Decimal(12, 2)
  total_upi         Decimal   @default(0) @db.Decimal(12, 2)
  total_card        Decimal   @default(0) @db.Decimal(12, 2)
  total_other       Decimal   @default(0) @db.Decimal(12, 2)
  total_discounts   Decimal   @default(0) @db.Decimal(12, 2)
  total_refunds     Decimal   @default(0) @db.Decimal(12, 2)
  closed_by         String?
  closed_at         DateTime?
  notes             String?
  created_at        DateTime  @default(now())
  created_by        String
  updated_at        DateTime  @updatedAt
  updated_by        String
  version           Int       @default(1)

  branch mdm_branches @relation(fields: [branch_id], references: [id])

  @@unique([tenant_id, branch_id, close_date])
  @@index([tenant_id, branch_id])
}

// ============================================================
// SHARED / INFRASTRUCTURE
// ============================================================

model domain_events {
  id             String    @id @default(uuid())
  tenant_id      String
  event_type     String    // BillConfirmed, PaymentReceived, SampleAccessioned, ResultSignedOff, DailyBranchCloseCompleted
  aggregate_type String    // Bill, Payment, Sample, Result, BranchClose
  aggregate_id   String
  payload        Json
  status         String    @default("PENDING") // PENDING, PROCESSED, FAILED
  created_at     DateTime  @default(now())
  processed_at   DateTime?

  @@index([tenant_id, event_type, status])
  @@index([tenant_id, aggregate_type, aggregate_id])
}

model number_sequences {
  id           String   @id @default(uuid())
  tenant_id    String
  branch_id    String
  prefix       String   // BILL, ACC, VIS, RPT, PAT
  current_date String   // YYYYMMDD
  last_value   Int      @default(0)

  @@unique([tenant_id, branch_id, prefix, current_date])
}

model config_settings {
  id          String   @id @default(uuid())
  tenant_id   String
  branch_id   String?  // null = tenant-level, set = branch-level override
  key         String   // e.g. discount.max_percent, rounding.nearest, payment.modes_allowed
  value       String   // JSON string
  description String?
  created_at  DateTime @default(now())
  created_by  String
  updated_at  DateTime @updatedAt
  updated_by  String

  @@unique([tenant_id, branch_id, key])
  @@index([tenant_id, key])
}
