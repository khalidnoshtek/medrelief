# ─── Required ───
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
JWT_SECRET="change-me-min-8-chars"
JWT_EXPIRES_IN="8h"
PORT=4782
NODE_ENV=development
DEFAULT_TENANT_ID="00000000-0000-0000-0000-000000000001"

# ─── AI extraction ───
# Provider: mock | claude | google | tesseract
# - mock (default): free, returns canned data, for dev
# - claude: uses Anthropic Claude Vision, needs ANTHROPIC_API_KEY
EXTRACTION_PROVIDER=mock
# ANTHROPIC_API_KEY=sk-ant-api03-...
# ANTHROPIC_MODEL=claude-haiku-4-5  # optional override

# ─── Email (optional) ───
# Leave blank to auto-create Ethereal test account on first send
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
